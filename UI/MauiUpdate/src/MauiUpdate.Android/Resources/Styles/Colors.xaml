<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary -->
    <Color x:Key="Primary">#6200EE</Color>
    <Color x:Key="PrimaryDark">#3700B3</Color>
    <Color x:Key="PrimaryLight">#BB86FC</Color>

    <!-- Accent -->
    <Color x:Key="Accent">#FF5722</Color>
    <Color x:Key="AccentLight">#FF8A65</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#2E7D32</Color>
    <Color x:Key="Warning">#FF8F00</Color>
    <Color x:Key="Error">#D32F2F</Color>

    <!-- Neutral -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#F5F5F5</Color>
    <Color x:Key="Gray200">#E0E0E0</Color>
    <Color x:Key="Gray300">#BDBDBD</Color>
    <Color x:Key="Gray500">#666666</Color>
    <Color x:Key="Gray900">#212121</Color>

</ResourceDictionary>
